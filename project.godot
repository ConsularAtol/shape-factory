buses/default_bus_layout="uid://dtgeuhuxjrfy6"

[autoload]

Global="*res://scenes/Global.gd"
ControllerIcons="*uid://dptbhk04asopp"
Dialogic="*uid://ds2q0uclmolvu"

[dialogic]

